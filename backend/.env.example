# MySQL из infra/docker-compose (порт 3306)
DATABASE_URL=mysql+aiomysql://app:app@127.0.0.1:3306/app?charset=utf8mb4

# Локально без Docker:
# DATABASE_URL=sqlite+aiosqlite:///./local.db

OPENAI_API_KEY=sk-replace-me
OPENAI_ASR_MODEL=gpt-4o-mini-transcribe

# Куда складывать загруженные wav для ASR
LOCAL_AUDIO_DIR=./data/audio

# Необязательно: абсолютный или относительно папки backend путь к каталогу с intent-моделью
# (должны лежать config.json, tokenizer*, model.safetensors или pytorch_model.bin)
# По умолчанию: app/models/intent1.0 (веса могут быть во вложенной папке, напр. intent_model_final)
# INTENT_MODEL_DIR=./app/models/intent1.0
# Для обученной Intent 1.0 в label_map.json часто unknown_threshold=0.65 — можно подобрать порог:
# INTENT_CONFIDENCE_THRESHOLD=0.55
